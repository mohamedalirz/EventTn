{
  "info": {
    "name": "EventTN API",
    "description": "Complete API collection for the EventTN Event Management Platform backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" },
    { "key": "organizerToken", "value": "" },
    { "key": "sponsorToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "eventId", "value": "" },
    { "key": "sponsorshipId", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Organizer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json().data;",
                  "  pm.collectionVariables.set('organizerToken', data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullname\": \"Amine Organizer\",\n  \"email\": \"organizer@eventtn.com\",\n  \"password\": \"password123\",\n  \"role\": \"ORGANIZER\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
          }
        },
        {
          "name": "Register Sponsor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json().data;",
                  "  pm.collectionVariables.set('sponsorToken', data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullname\": \"Sara Sponsor\",\n  \"email\": \"sponsor@eventtn.com\",\n  \"password\": \"password123\",\n  \"role\": \"SPONSOR\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json().data;",
                  "  pm.collectionVariables.set('token', data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"organizer@eventtn.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Login as Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json().data;",
                  "  pm.collectionVariables.set('adminToken', data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@eventtn.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "Get All Events",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/events", "host": ["{{baseUrl}}"], "path": ["api", "events"] }
          }
        },
        {
          "name": "Get Event by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/events/{{eventId}}", "host": ["{{baseUrl}}"], "path": ["api", "events", "{{eventId}}"] }
          }
        },
        {
          "name": "Get My Events (Organizer)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{organizerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/events/organizer/my-events", "host": ["{{baseUrl}}"], "path": ["api", "events", "organizer", "my-events"] }
          }
        },
        {
          "name": "Create Event",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json().data;",
                  "  pm.collectionVariables.set('eventId', data.event.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{organizerToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Tunis Tech Summit 2026", "type": "text" },
                { "key": "description", "value": "A gathering of the best tech minds in Tunisia.", "type": "text" },
                { "key": "category", "value": "Technology", "type": "text" },
                { "key": "city", "value": "Tunis", "type": "text" },
                { "key": "venue", "value": "Palais des Congrès", "type": "text" },
                { "key": "eventDate", "value": "2026-10-15T09:00:00.000Z", "type": "text" },
                { "key": "ticketPrice", "value": "50", "type": "text" },
                { "key": "totalTickets", "value": "500", "type": "text" },
                { "key": "featured", "value": "true", "type": "text" },
                { "key": "banner", "type": "file", "src": [] }
              ]
            },
            "url": { "raw": "{{baseUrl}}/api/events", "host": ["{{baseUrl}}"], "path": ["api", "events"] }
          }
        },
        {
          "name": "Update Event",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{organizerToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Tunis Tech Summit 2026 - Updated", "type": "text" },
                { "key": "ticketPrice", "value": "60", "type": "text" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/api/events/{{eventId}}", "host": ["{{baseUrl}}"], "path": ["api", "events", "{{eventId}}"] }
          }
        },
        {
          "name": "Delete Event",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{organizerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/events/{{eventId}}", "host": ["{{baseUrl}}"], "path": ["api", "events", "{{eventId}}"] }
          }
        }
      ]
    },
    {
      "name": "Sponsors",
      "item": [
        {
          "name": "Browse Events (Sponsor)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{sponsorToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/sponsors/events", "host": ["{{baseUrl}}"], "path": ["api", "sponsors", "events"] }
          }
        }
      ]
    },
    {
      "name": "Sponsorships",
      "item": [
        {
          "name": "Create Sponsorship Request",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json().data;",
                  "  pm.collectionVariables.set('sponsorshipId', data.request.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{sponsorToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"{{eventId}}\",\n  \"message\": \"We'd love to sponsor this event with our brand.\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/sponsorships", "host": ["{{baseUrl}}"], "path": ["api", "sponsorships"] }
          }
        },
        {
          "name": "Get My Sponsorship Requests (Sponsor)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{sponsorToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/sponsorships/my", "host": ["{{baseUrl}}"], "path": ["api", "sponsorships", "my"] }
          }
        },
        {
          "name": "Get Organizer Sponsorship Requests",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{organizerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/organizer/sponsorships", "host": ["{{baseUrl}}"], "path": ["api", "organizer", "sponsorships"] }
          }
        },
        {
          "name": "Update Sponsorship Status (Accept/Reject)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{organizerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ACCEPTED\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/sponsorships/{{sponsorshipId}}", "host": ["{{baseUrl}}"], "path": ["api", "sponsorships", "{{sponsorshipId}}"] }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/users", "host": ["{{baseUrl}}"], "path": ["api", "admin", "users"] }
          }
        },
        {
          "name": "Get All Events",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/events", "host": ["{{baseUrl}}"], "path": ["api", "admin", "events"] }
          }
        },
        {
          "name": "Get All Sponsorships",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/sponsorships", "host": ["{{baseUrl}}"], "path": ["api", "admin", "sponsorships"] }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["api", "admin", "users", "{{userId}}"] }
          }
        },
        {
          "name": "Delete Event",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/events/{{eventId}}", "host": ["{{baseUrl}}"], "path": ["api", "admin", "events", "{{eventId}}"] }
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/health", "host": ["{{baseUrl}}"], "path": ["api", "health"] }
          }
        }
      ]
    }
  ]
}
