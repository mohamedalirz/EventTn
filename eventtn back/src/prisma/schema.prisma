generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ORGANIZER
  SPONSOR
}

enum SponsorshipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model User {
  id        String   @id @default(uuid())
  fullname  String
  email     String   @unique
  password  String
  role      Role     @default(SPONSOR)
  createdAt DateTime @default(now())

  events              Event[]              @relation("OrganizerEvents")
  sponsorshipRequests SponsorshipRequest[] @relation("SponsorRequests")

  @@map("users")
}

model Event {
  id           String   @id @default(uuid())
  title        String
  description  String
  banner       String?
  category     String
  city         String
  venue        String
  eventDate    DateTime
  ticketPrice  Float    @default(0)
  totalTickets Int      @default(0)
  featured     Boolean  @default(false)
  organizerId  String
  createdAt    DateTime @default(now())

  organizer           User                  @relation("OrganizerEvents", fields: [organizerId], references: [id], onDelete: Cascade)
  sponsorshipRequests SponsorshipRequest[]

  @@map("events")
}

model SponsorshipRequest {
  id        String            @id @default(uuid())
  sponsorId String
  eventId   String
  message   String
  status    SponsorshipStatus @default(PENDING)
  createdAt DateTime          @default(now())

  sponsor User  @relation("SponsorRequests", fields: [sponsorId], references: [id], onDelete: Cascade)
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("sponsorship_requests")
}
